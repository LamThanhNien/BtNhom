@{
    Layout = "_SecureLayout";
    ViewData["Title"] = "Dashboard";
}

<div class="row"></div>
<div class="row padding-top-20px padding-left-20px padding-right-20px">

    <!-- Welcome Banner -->
    <div class="row">
        <div class="col s12">
            <div class="card blue-grey darken-1 z-depth-2">
                <div class="card-content white-text">
                    <div class="row valign-wrapper" style="margin-bottom:0;">
                        <div class="col s2 center hide-on-small-only">
                            <i class="material-icons" style="font-size:64px; opacity:0.8;">directions_car</i>
                        </div>
                        <div class="col s12 m10">
                            <span class="card-title" style="font-size:22px;">
                                Welcome to Automobile Service Center
                            </span>
                            <p class="grey-text text-lighten-2" style="margin-top:6px;">
                                Manage vehicle service requests, track progress, and coordinate with your team — all in one place.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="row">
        <div class="col s12 m4">
            <div class="card hoverable z-depth-2">
                <div class="card-content center-align">
                    <i class="material-icons large teal-text">assignment</i>
                    <p class="blue-grey-text text-darken-2" style="font-size:16px; font-weight:500;">Service Requests</p>
                    <p class="grey-text">View and manage all active service requests</p>
                </div>
                <div class="card-action center-align">
                    <a href="/ServiceRequests/Dashboard/Dashboard" class="btn waves-effect waves-light teal">
                        <i class="material-icons left">dashboard</i>Open Dashboard
                    </a>
                </div>
            </div>
        </div>

        @if (User.IsInRole("User"))
        {
            <div class="col s12 m4">
                <div class="card hoverable z-depth-2">
                    <div class="card-content center-align">
                        <i class="material-icons large blue-grey-text">add_circle_outline</i>
                        <p class="blue-grey-text text-darken-2" style="font-size:16px; font-weight:500;">New Service Request</p>
                        <p class="grey-text">Submit a new vehicle service request</p>
                    </div>
                    <div class="card-action center-align">
                        <a href="/ServiceRequests/ServiceRequest/ServiceRequest" class="btn waves-effect waves-light blue-grey darken-1">
                            <i class="material-icons left">add</i>Create Request
                        </a>
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole("Admin"))
        {
            <div class="col s12 m4">
                <div class="card hoverable z-depth-2">
                    <div class="card-content center-align">
                        <i class="material-icons large orange-text">supervisor_account</i>
                        <p class="blue-grey-text text-darken-2" style="font-size:16px; font-weight:500;">User Administration</p>
                        <p class="grey-text">Manage customers and service engineers</p>
                    </div>
                    <div class="card-action center-align">
                        <a href="/Accounts/Account/ServiceEngineers" class="btn waves-effect waves-light orange darken-1">
                            <i class="material-icons left">people</i>Manage Users
                        </a>
                    </div>
                </div>
            </div>
            <div class="col s12 m4">
                <div class="card hoverable z-depth-2">
                    <div class="card-content center-align">
                        <i class="material-icons large indigo-text text-lighten-2">settings</i>
                        <p class="blue-grey-text text-darken-2" style="font-size:16px; font-weight:500;">Master Data</p>
                        <p class="grey-text">Configure vehicle types, names, and service statuses</p>
                    </div>
                    <div class="card-action center-align">
                        <a href="/Configuration/MasterData/MasterKeys" class="btn waves-effect waves-light indigo lighten-2">
                            <i class="material-icons left">perm_data_setting</i>Configure
                        </a>
                    </div>
                </div>
            </div>
        }

        @if (User.IsInRole("Engineer"))
        {
            <div class="col s12 m4">
                <div class="card hoverable z-depth-2">
                    <div class="card-content center-align">
                        <i class="material-icons large green-text">build</i>
                        <p class="blue-grey-text text-darken-2" style="font-size:16px; font-weight:500;">My Assignments</p>
                        <p class="grey-text">View and update your assigned service jobs</p>
                    </div>
                    <div class="card-action center-align">
                        <a href="/ServiceRequests/Dashboard/Dashboard" class="btn waves-effect waves-light green darken-1">
                            <i class="material-icons left">playlist_add_check</i>My Jobs
                        </a>
                    </div>
                </div>
            </div>
        }

        <div class="col s12 m4">
            <div class="card hoverable z-depth-2">
                <div class="card-content center-align">
                    <i class="material-icons large brown-text text-lighten-1">account_circle</i>
                    <p class="blue-grey-text text-darken-2" style="font-size:16px; font-weight:500;">My Profile</p>
                    <p class="grey-text">Update your account username and settings</p>
                </div>
                <div class="card-action center-align">
                    <a href="/Accounts/Account/Profile" class="btn waves-effect waves-light brown lighten-1">
                        <i class="material-icons left">edit</i>Edit Profile
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- About Section -->
    <div class="row">
        <div class="col s12">
            <div class="card z-depth-1">
                <div class="card-content">
                    <span class="card-title blue-grey-text text-darken-2">
                        <i class="material-icons left">info_outline</i>About This System
                    </span>
                    <div class="row" style="margin-top:10px;">
                        <div class="col s12 m4">
                            <div class="center-align">
                                <i class="material-icons medium teal-text">verified_user</i>
                                <h6 class="blue-grey-text">Role-Based Access</h6>
                                <p class="grey-text" style="font-size:13px;">
                                    Admin, Service Engineer, and Customer roles each have tailored views and permissions.
                                </p>
                            </div>
                        </div>
                        <div class="col s12 m4">
                            <div class="center-align">
                                <i class="material-icons medium teal-text">track_changes</i>
                                <h6 class="blue-grey-text">Request Tracking</h6>
                                <p class="grey-text" style="font-size:13px;">
                                    Full lifecycle tracking from New → Initiated → In Progress → Completed.
                                </p>
                            </div>
                        </div>
                        <div class="col s12 m4">
                            <div class="center-align">
                                <i class="material-icons medium teal-text">notifications_active</i>
                                <h6 class="blue-grey-text">Email Notifications</h6>
                                <p class="grey-text" style="font-size:13px;">
                                    Automatic email alerts keep customers and engineers informed on account changes.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
