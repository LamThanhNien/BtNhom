                <p class="white-text">Automobile Service Center</p>
            </div>
        </div>
    </div>
</footer>

@section Scripts {
    <script type="text/javascript">
        $(function () {
            $('.sidenav').sidenav();
        });
    </script>
    @RenderSection("Scripts", required: false)
