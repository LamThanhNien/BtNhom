@inject Microsoft.Extensions.Options.IOptions<ASC.Web.Models.ApplicationSettings> settings
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @settings.Value.ApplicationName</title>

    <!-- Material Icons -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

    <!-- Materialize CSS -->
    <link rel="stylesheet" href="~/css/materialize.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="light-blue lighten-1" role="navigation">
        <div class="nav-wrapper container">
            <a id="logo-container" href="#" class="brand-logo">@settings.Value.ApplicationName</a>
            <ul class="right hide-on-med-and-down">
                <li><a href="#">Dashboard</a></li>
                <li><a href="#">Service Requests</a></li>
                <li><a href="#">Master Data</a></li>
                <li><a asp-area="Identity" asp-page="/Account/Logout">Logout</a></li>
            </ul>
            <ul id="nav-mobile" class="sidenav">
                <li><a href="#">Dashboard</a></li>
                <li><a href="#">Service Requests</a></li>
                <li><a href="#">Master Data</a></li>
                <li><a asp-area="Identity" asp-page="/Account/Logout">Logout</a></li>
            </ul>
            <a href="#" data-target="nav-mobile" class="sidenav-trigger"><i class="material-icons">menu</i></a>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Materialize JS -->
    <script src="~/js/materialize.js"></script>

    <!-- Khởi tạo Materialize components -->
    <script>
        $(document).ready(function(){
        $('.sidenav').sidenav();
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>