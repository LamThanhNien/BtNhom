@page
@model ASC.Web.Areas.Identity.Pages.Account.InitiateResetPasswordModel
@{
    ViewData["Title"] = "Initiate Reset Password";
    Layout = "_SecureLayout";
}

<div class="container section">
    <div class="row">
        <div class="col s12 m8 l7">
            <div class="card">
                <div class="card-content">
                    <span class="card-title">Reset Password</span>
                    <p>A reset link will be sent to your email address.</p>
                    <div asp-validation-summary="All" class="validation-summary-errors"></div>
                    <form method="post">
                        <div class="input-field">
                            <input asp-for="Input.Email" />
                            <label asp-for="Input.Email"></label>
                            <span asp-validation-for="Input.Email" class="field-validation-error"></span>
                        </div>
                        <button type="submit" class="btn waves-effect waves-light">Send Reset Link</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
