@page
@model ASC.Web.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
}

<div class="container section">
    <h4>Login</h4>
    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="red-text"></div>
        <div class="input-field">
            <input asp-for="Input.Email" />
            <label asp-for="Input.Email"></label>
        </div>
        <div class="input-field">
            <input asp-for="Input.Password" />
            <label asp-for="Input.Password"></label>
        </div>
        <p>
            <label>
                <input asp-for="Input.RememberMe" type="checkbox" />
                <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
            </label>
        </p>
        <button type="submit" class="btn waves-effect waves-light">Log in</button>
        <a id="forgot-password" asp-page="./ForgotPassword" class="btn-flat">Forgot password?</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
