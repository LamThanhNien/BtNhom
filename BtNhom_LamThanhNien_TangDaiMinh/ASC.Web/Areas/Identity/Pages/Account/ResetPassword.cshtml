@page
@model ASC.Web.Areas.Identity.Pages.Account.ResetPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_Layout";
}

<div class="container section">
    <div class="row">
        <div class="col s12 m8 l6 offset-m2 offset-l3">
            <div class="card">
                <div class="card-content">
                    <span class="card-title">Reset Password</span>
                    <div asp-validation-summary="All" class="validation-summary-errors"></div>
                    <form method="post">
                        <input asp-for="Input.Code" type="hidden" />

                        <div class="input-field">
                            <input asp-for="Input.Email" />
                            <label asp-for="Input.Email"></label>
                            <span asp-validation-for="Input.Email" class="field-validation-error"></span>
                        </div>

                        <div class="input-field">
                            <input asp-for="Input.Password" />
                            <label asp-for="Input.Password"></label>
                            <span asp-validation-for="Input.Password" class="field-validation-error"></span>
                        </div>

                        <div class="input-field">
                            <input asp-for="Input.ConfirmPassword" />
                            <label asp-for="Input.ConfirmPassword"></label>
                            <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
                        </div>

                        <button type="submit" class="btn waves-effect waves-light">Reset Password</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
