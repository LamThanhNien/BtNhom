@{
    ViewData["Title"] = "Dashboard";
    Layout = "_SecureLayout";
}

<div class="row">
    <div class="col s12 m6 l4">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Service Requests</span>
                <p>Overview of your service activities.</p>
            </div>
        </div>
    </div>
    <div class="col s12 m6 l4">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Notifications</span>
                <p>Latest updates and alerts.</p>
            </div>
        </div>
    </div>
    <div class="col s12 m6 l4">
        <div class="card">
            <div class="card-content">
                <span class="card-title">Promotions</span>
                <p>Current campaigns and offers.</p>
            </div>
        </div>
    </div>
</div>
