@model IEnumerable<ASC.Model.ServiceRequest>
@{
    var isAudit = ViewBag.IsAudit != null && (bool)ViewBag.IsAudit;
    var sectionName = ViewBag.SectionName?.ToString() ?? "Service Requests";
    var tableId = ViewBag.Id?.ToString() ?? "tblServiceRequests";

    static string NormalizeStatus(string? status)
    {
        return (status ?? string.Empty).Replace(" ", string.Empty).Trim().ToUpper();
    }

    static string GetStatusCssClass(string? status)
    {
        var normalizedStatus = NormalizeStatus(status);

        return normalizedStatus switch
        {
            "NEW" or "INITIATED" or "INPROGRESS" => "white-text teal lighten-1 center-align",
            "COMPLETED" => "white-text green darken-1 center-align",
            "REQUESTFORINFORMATION" or "PENDING" or "DENIED" => "white-text red lighten-1 center-align",
            "PENDINGCUSTOMERAPPROVAL" => "white-text orange lighten-1 center-align",
            _ => "white-text blue-grey lighten-1 center-align"
        };
    }
}

<div class="row"></div>
<div class="row padding-top-20px">
    <div class="row z-depth-3">
        <div class="section white-text padding-left-10px blue-grey lighten-1">
            <h5>@sectionName</h5>
        </div>
        <div class="divider"></div>

        <div class="col s12 padding-bottom-15px">
            <table class="highlight centered tblServiceRequests" id="@tableId">
                <thead>
                    <tr>
                        <th data-field="RowKey">RowKey</th>
                        <th data-field="PartitionKey">PartitionKey</th>
                        <th data-field="User">User</th>
                        <th data-field="Status">Status</th>
                        <th data-field="RequestedDate">Requested Date</th>
                        <th data-field="ServiceEngineer">Service Engineer</th>
                        @if (isAudit)
                        {
                            <th data-field="RequestedServices">Requested Services</th>
                        }
                        <th data-field="Actions">View</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var serviceRequest in Model)
                    {
                        <tr>
                            <td>@serviceRequest.RowKey</td>
                            <td>@serviceRequest.PartitionKey</td>
                            @{
                                var partitionKey = serviceRequest.PartitionKey ?? string.Empty;
                                var userDisplay = !partitionKey.Contains('-')
                                    ? partitionKey
                                    : partitionKey.Split(new[] { '-' })[0];
                            }
                            <td>@userDisplay</td>
                            <td>
                                <div class="@GetStatusCssClass(serviceRequest.Status)">
                                    <span>@serviceRequest.Status</span>
                                </div>
                            </td>
                            <td>@(serviceRequest.RequestedDate.HasValue ? serviceRequest.RequestedDate.Value.ToString("dd/MM/yyyy") : string.Empty)</td>
                            <td>@serviceRequest.ServiceEngineer</td>
                            @if (isAudit)
                            {
                                var trimText = string.IsNullOrWhiteSpace(serviceRequest.RequestedServices)
                                    ? string.Empty
                                    : serviceRequest.RequestedServices.Length > 50
                                        ? string.Format("{0}...", serviceRequest.RequestedServices.Substring(0, 50))
                                        : serviceRequest.RequestedServices;
                                <td title="@serviceRequest.RequestedServices">@trimText</td>
                            }
                            <td>
                                <i class="small material-icons view cursor-hand"
                                   data-rowkey="@serviceRequest.RowKey"
                                   data-partitionkey="@serviceRequest.PartitionKey"
                                   data-customer="@userDisplay"
                                   data-vehiclename="@serviceRequest.VehicleName"
                                   data-vehicletype="@serviceRequest.VehicleType"
                                   data-status="@serviceRequest.Status"
                                   data-requesteddate="@(serviceRequest.RequestedDate.HasValue ? serviceRequest.RequestedDate.Value.ToString("dd/MM/yyyy") : string.Empty)"
                                   data-completeddate="@(serviceRequest.CompletedDate.HasValue ? serviceRequest.CompletedDate.Value.ToString("dd/MM/yyyy") : string.Empty)"
                                   data-requestedservices="@serviceRequest.RequestedServices"
                                   data-serviceengineer="@(serviceRequest.ServiceEngineer ?? string.Empty)">pageview</i>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
