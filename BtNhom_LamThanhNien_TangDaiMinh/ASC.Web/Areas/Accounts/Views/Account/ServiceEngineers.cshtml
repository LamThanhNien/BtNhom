@model ServiceEngineerViewModel
@{
    ViewData["Title"] = "Service Engineers";
}

<div class="container section">
    <h4>Service Engineers</h4>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="card-panel green lighten-4 green-text text-darken-4">@successMessage</div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="card-panel red lighten-4 red-text text-darken-4">@errorMessage</div>
    }

    <div class="row">
        <div class="col s12 m7">
            <table id="tblServiceEngineers" class="striped">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>User Name</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var engineer in Model.ServiceEngineers)
                {
                    <tr>
                        <td>@engineer.Email</td>
                        <td>@engineer.UserName</td>
                        <td>@(engineer.IsActive ? "Active" : "Inactive")</td>
                        <td>
                            <button type="button"
                                    class="btn-small blue edit-engineer"
                                    data-id="@engineer.Id"
                                    data-email="@engineer.Email"
                                    data-username="@engineer.UserName"
                                    data-active="@engineer.IsActive">
                                Edit
                            </button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div class="col s12 m5">
            <h5 id="engineer-form-title">Add / Update Engineer</h5>
            <form asp-action="ServiceEngineers" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <input asp-for="Registration.Id" type="hidden" id="Registration_Id" />

                <div class="input-field">
                    <input asp-for="Registration.Email" id="Registration_Email" />
                    <label asp-for="Registration.Email"></label>
                    <span asp-validation-for="Registration.Email" class="helper-text red-text"></span>
                </div>

                <div class="input-field">
                    <input asp-for="Registration.UserName" id="Registration_UserName" />
                    <label asp-for="Registration.UserName"></label>
                    <span asp-validation-for="Registration.UserName" class="helper-text red-text"></span>
                </div>

                <div class="input-field">
                    <input asp-for="Registration.Password" id="Registration_Password" />
                    <label asp-for="Registration.Password"></label>
                    <span asp-validation-for="Registration.Password" class="helper-text red-text"></span>
                </div>

                <p>
                    <label>
                        <input asp-for="Registration.IsActive" type="checkbox" id="Registration_IsActive" />
                        <span>Is Active</span>
                    </label>
                </p>

                <div class="datatable-actions">
                    <button type="submit" class="btn waves-effect waves-light">Save</button>
                    <button type="button" id="btnResetEngineer" class="btn grey">Reset</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="text/javascript">
        $(function () {
            if ($.fn.DataTable) {
                $('#tblServiceEngineers').DataTable();
            }

            function resetEngineerForm() {
                $('#Registration_Id').val('');
                $('#Registration_Email').val('');
                $('#Registration_UserName').val('');
                $('#Registration_Password').val('');
                $('#Registration_IsActive').prop('checked', true);
                $('#engineer-form-title').text('Add / Update Engineer');
                M.updateTextFields();
            }

            $('.edit-engineer').on('click', function () {
                $('#Registration_Id').val($(this).data('id'));
                $('#Registration_Email').val($(this).data('email'));
                $('#Registration_UserName').val($(this).data('username'));
                $('#Registration_Password').val('');
                $('#Registration_IsActive').prop('checked', $(this).data('active') === true || $(this).data('active') === 'True');
                $('#engineer-form-title').text('Update Engineer');
                M.updateTextFields();
            });

            $('#btnResetEngineer').on('click', resetEngineerForm);
        });
    </script>
}
