@model ASC.Web.Areas.ServiceNotifications.Models.NotificationDashboardViewModel
@{
    Layout = "_SecureLayout";
    ViewData["Title"] = "Service Notifications";
}

<div class="row"></div>
<div class="row padding-top-20px padding-left-20px padding-right-20px">
    <div class="row z-depth-3">
        <div class="section white-text padding-left-10px blue-grey lighten-1">
            <h5>Service Notifications</h5>
        </div>
        <div class="divider"></div>

        <div class="col s12" style="padding:16px 16px 8px;">
            <p class="blue-grey-text text-darken-2" style="margin:0;">
                Latest notification feed for your service requests and status changes.
            </p>
        </div>

        <div class="col s12 padding-bottom-15px">
            <table class="highlight centered" id="tblServiceNotifications">
                <thead>
                    <tr>
                        <th data-field="Message">Notification</th>
                        <th data-field="Status">Status</th>
                        <th data-field="Vehicle">Vehicle</th>
                        <th data-field="ServiceEngineer">Service Engineer</th>
                        <th data-field="NotificationDate">Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Notifications)
                    {
                        <tr>
                            <td class="left-align">@item.Message</td>
                            <td>@item.Status</td>
                            <td>@item.VehicleName (@item.VehicleType)</td>
                            <td>@(string.IsNullOrWhiteSpace(item.ServiceEngineer) ? "Not assigned" : item.ServiceEngineer)</td>
                            <td>@(item.NotificationDate.HasValue ? item.NotificationDate.Value.ToString("dd/MM/yyyy") : string.Empty)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tblServiceNotifications').DataTable({
                pageLength: 5,
                lengthMenu: [[5, 10, 20, -1], [5, 10, 20, 'All']],
                order: [[4, 'desc']]
            });

            $('select[name="tblServiceNotifications_length"]').formSelect();
        });
    </script>
}
