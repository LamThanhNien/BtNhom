  },
  {
    "index": 4,
    "style": "List Paragraph",
    "text": "B1. Cài chocolate"
  },
  {
    "index": 5,
    "style": "List Paragraph",
    "text": "Mở cmd với quyền admin"
  },
  {
    "index": 6,
    "style": "HTML Preformatted",
    "text": "> @\"%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe\" -NoProfile -InputFormat None -ExecutionPolicy Bypass -Command \"iex ((New-Object System.Net.WebClient).DownloadString('https://chocolatey.org/install.ps1'))\" && SET \"PATH=%PATH%;%ALLUSERSPROFILE%\\chocolatey\\bin\""
  },
  {
    "index": 7,
    "style": "HTML Preformatted",
    "text": ">choco -v"
  },
  {
    "index": 9,
    "style": "List Paragraph",
    "text": "B2. Cài Redis"
  },
  {
    "index": 10,
    "style": "Normal",
    "text": "> choco install redis-64"
  },
  {
    "index": 11,
    "style": "Normal",
    "text": "Run Redis"
  },
  {
    "index": 12,
    "style": "Normal",
    "text": ">redis-server"
  },
  {
    "index": 14,
    "style": "Normal",
    "text": "Chú ý port kết nối với redis là 6379 qua localhost"
  },
  {
    "index": 15,
